{
  "name": "@forgeax/hello-multi-uv",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Multi-UV visual differentiation demo (AC-10): plane with 2 UV sets rendered through built-in PBR shader.",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-dawn.mjs"
  },
  "forgeax": {
    "smokeInvocation": "pnpm --filter @forgeax/hello-multi-uv smoke",
    "metrics": {
      "bundle-size": {
        "enabled": false,
        "reason": "vite app bundle downstream of @forgeax/engine-runtime sizes tracked at the package level"
      },
      "fps": {
        "enabled": false,
        "reason": "visual differentiation demo, not a FPS benchmark target"
      },
      "bench": {
        "enabled": false,
        "reason": "bench focus stays on @forgeax/engine-math"
      },
      "gate": {
        "enabled": true,
        "command": "pnpm --filter @forgeax/hello-multi-uv smoke"
      },
      "spike-report": {
        "enabled": false,
        "reason": "not a spike app"
      }
    }
  },
  "dependencies": {
    "@forgeax/engine-app": "workspace:*",
    "@forgeax/engine-runtime": "workspace:*",
    "@forgeax/engine-types": "workspace:*"
  },
  "devDependencies": {
    "@forgeax/engine-vite-plugin-shader": "workspace:*",
    "vite": "8.0.10",
    "webgpu": "^0.4.0",
    "@webgpu/types": "^0.1.71"
  }
}