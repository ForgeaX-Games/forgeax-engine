{
  "name": "@forgeax/rhi-debug-viewer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "RHI debug tape viewer — offline visualizer consuming PR1-PR3 capture/inspect primitives",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "smoke:browser": "node scripts/smoke-browser.mjs",
    "smoke:browser:no-webgpu": "node scripts/smoke-browser-no-webgpu.mjs"
  },
  "forgeax": {
    "metrics": {
      "bundle-size": {
        "enabled": false,
        "reason": "viewer app bundle shape is downstream of @forgeax/engine-runtime + @forgeax/engine-rhi-webgpu sizes already tracked at the package level"
      },
      "fps": {
        "enabled": false,
        "reason": "fps anchors are hello-triangle / hello-cube; viewer is a tape inspection tool, not a render perf target"
      },
      "bench": {
        "enabled": false,
        "reason": "bench focus stays on @forgeax/engine-math and engine internals; viewer is a UI app"
      },
      "gate": {
        "enabled": true,
        "command": "pnpm --filter @forgeax/rhi-debug-viewer build"
      },
      "spike-report": {
        "enabled": false,
        "reason": "spike artefacts live under .forgeax-harness/forgeax-loop/; viewer is the consumer app, not a spike"
      }
    }
  },
  "dependencies": {
    "@forgeax/engine-rhi-debug": "workspace:*",
    "@forgeax/engine-rhi": "workspace:*",
    "@forgeax/engine-rhi-webgpu": "workspace:*",
    "@forgeax/engine-types": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dockview-react": "^7.0.2",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^26.0.0",
    "@webgpu/types": "^0.1.70",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.0",
    "vite": "8.0.10"
  }
}
