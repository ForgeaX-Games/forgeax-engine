{
  "name": "@forgeax/app-learn-render-5-advanced-lighting-9-ssao",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "learn-render LearnOpenGL section 5.advanced-lighting 9.ssao -- HDRP SSAO with config.ssao.enabled=true; enclosing room + backpack.gltf model + dim light + Skylight ambient (faithful LO 5.9 SSAO scene).",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-dawn.mjs",
    "smoke:discrimination": "node scripts/smoke-dawn.mjs --discrimination",
    "smoke:browser": "node scripts/smoke-browser.mjs"
  },
  "forgeax": {
    "smokeInvocation": "pnpm --filter @forgeax/app-learn-render-5-advanced-lighting-9-ssao smoke",
    "metrics": {
      "bundle-size": {
        "enabled": false,
        "reason": "vite app bundle (dist/assets) size is downstream of @forgeax/engine-runtime size already tracked at the package level"
      },
      "fps": {
        "enabled": false,
        "reason": "OOS-11 fps anchor stays on hello-triangle; per-app fps drift is not gated for learn-render examples"
      },
      "bench": {
        "enabled": false,
        "reason": "pixel-parity bench drives parity-forgeax vs parity-threejs; learn-render entries land as bench:pixel-parity placeholders only"
      },
      "gate": {
        "enabled": true,
        "command": "pnpm --filter @forgeax/app-learn-render-5-advanced-lighting-9-ssao smoke:discrimination"
      },
      "spike-report": {
        "enabled": false,
        "reason": "not a spike app; LearnOpenGL section-5.9 SSAO tutorial example"
      }
    }
  },
  "dependencies": {
    "@forgeax/apps-shared": "workspace:*",
    "@forgeax/engine-app": "workspace:*",
    "@forgeax/engine-assets-runtime": "workspace:*",
    "@forgeax/engine-ecs": "workspace:*",
    "@forgeax/engine-gltf": "workspace:*",
    "@forgeax/engine-image": "workspace:*",
    "@forgeax/engine-pack": "workspace:*",
    "@forgeax/engine-rhi-webgpu": "workspace:*",
    "@forgeax/engine-rhi-wgpu": "workspace:*",
    "@forgeax/engine-runtime": "workspace:*",
    "@forgeax/engine-types": "workspace:*"
  },
  "devDependencies": {
    "@forgeax/engine-rhi-debug": "workspace:*",
    "@forgeax/engine-vite-plugin-pack": "workspace:*",
    "@forgeax/engine-vite-plugin-rhi-debug": "workspace:*",
    "@forgeax/engine-vite-plugin-shader": "workspace:*",
    "@webgpu/types": "^0.1.71",
    "playwright": "^1.50.0",
    "vite": "8.0.10"
  }
}
