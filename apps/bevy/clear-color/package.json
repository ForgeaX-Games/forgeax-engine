{
  "name": "@forgeax/bevy-clear-color",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Bevy window/clear_color example: blue-ish background, Space to toggle to purple.",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-dawn.mjs"
  },
  "forgeax": {
    "bevyExample": { "name": "clear_color", "category": "Window", "status": "implemented" },
    "smokeInvocation": "pnpm --filter @forgeax/bevy-clear-color smoke",
    "metrics": {
      "bundle-size": { "enabled": false, "reason": "vite app bundle downstream of engine-runtime sizes already tracked at the package level" },
      "fps": { "enabled": false, "reason": "demo-specific fps evidence belongs to its completed reproduction" },
      "bench": { "enabled": false, "reason": "demo-specific benchmarks belong to its completed reproduction" },
      "gate": { "enabled": true, "command": "pnpm --filter @forgeax/bevy-clear-color smoke" },
      "spike-report": { "enabled": false, "reason": "not a spike app; Bevy example reproduction" }
    }
  },
  "dependencies": {
    "@forgeax/engine-app": "workspace:*",
    "@forgeax/engine-ecs": "workspace:*",
    "@forgeax/engine-input": "workspace:*",
    "@forgeax/engine-runtime": "workspace:*"
  },
  "devDependencies": {
    "@forgeax/engine-vite-plugin-shader": "workspace:*",
    "@webgpu/types": "^0.1.71",
    "vite": "8.0.10",
    "webgpu": "^0.4.0"
  }
}