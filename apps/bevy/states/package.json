{
  "name": "@forgeax/bevy-states",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Reproduce Bevy's `states` example: defineState, setNextState, OnEnter/OnExit callbacks.",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-dawn.mjs"
  },
  "forgeax": {
    "bevyExample": {
      "name": "states",
      "category": "State",
      "status": "implemented"
    },
    "smokeInvocation": "pnpm --filter @forgeax/bevy-states smoke",
    "metrics": {
      "bundle-size": {
        "enabled": false,
        "reason": "vite app bundle downstream of engine-runtime sizes already tracked at the package level"
      },
      "fps": {
        "enabled": false,
        "reason": "demo-specific fps evidence belongs to its completed reproduction"
      },
      "bench": {
        "enabled": false,
        "reason": "demo-specific benchmarks belong to its completed reproduction"
      },
      "gate": {
        "enabled": true,
        "command": "pnpm --filter @forgeax/bevy-states smoke"
      },
      "spike-report": {
        "enabled": false,
        "reason": "not a spike app; Bevy example reproduction"
      }
    }
  },
  "dependencies": {
    "@forgeax/engine-app": "workspace:*",
    "@forgeax/engine-ecs": "workspace:*",
    "@forgeax/engine-math": "workspace:*",
    "@forgeax/engine-runtime": "workspace:*",
    "@forgeax/engine-state": "workspace:*"
  },
  "devDependencies": {
    "@forgeax/engine-vite-plugin-shader": "workspace:*",
    "@webgpu/types": "^0.1.71",
    "vite": "8.0.10",
    "webgpu": "^0.4.0"
  }
}
