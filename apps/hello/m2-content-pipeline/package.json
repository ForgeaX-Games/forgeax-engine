{
  "name": "@forgeax/hello-m2-content-pipeline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "M2 content-pipeline gauntlet: project manifest, sidecar scan, host importer delivery, GUID reimport, and codec round-trip.",
  "scripts": {
    "smoke": "node scripts/smoke.mjs"
  },
  "forgeax": {
    "smokeInvocation": "pnpm --filter @forgeax/hello-m2-content-pipeline smoke",
    "gauntletScenario": {
      "id": "hello-m2-content-pipeline",
      "script": "smoke",
      "domains": ["Asset schemas, import, and delivery", "World and host contract", "Inspection, debugging, and development bridges"],
      "packages": ["@forgeax/engine-codec", "@forgeax/engine-fbx", "@forgeax/engine-image", "@forgeax/engine-pack", "@forgeax/engine-project"],
      "risks": ["baseline", "content", "build", "delivery", "fault", "recovery", "behavioral"],
      "phaseInputs": ["baseline", "content", "build", "delivery", "fault", "recovery"],
      "evidence": {
        "frontDoors": ["node-app", "vite-pack", "browser-hmr", "project-manifest", "content-catalog"],
        "legs": ["semantic", "recovery"]
      },
      "oracle": {
        "stdoutIncludes": ["[m2-content] project manifest: PASS", "[m2-content] sidecar scan: PASS", "[m2-content] host importer delivery: PASS", "[smoke-browser] PASS - browser HMR reloaded changed host asset content", "[m2-content] browser HMR delivery: PASS", "[m2-content] FBX fixture reimport: PASS", "[m2-content] font fixture delivery: PASS", "[m2-content] font + FBX fixture delivery: PASS", "[m2-content] GUID reimport: PASS", "[m2-content] codec round-trip: PASS", "[m2-content] PASS - M2 partial content pipeline gates GREEN"]
      }
    },
    "metrics": {
      "bundle-size": {"enabled": false, "reason": "content audit has no dedicated browser bundle; Vite pack delivery is delegated to the host importer scenario"},
      "fps": {"enabled": false, "reason": "content pipeline scenario has no frame-rate claim"},
      "bench": {"enabled": false, "reason": "codec round-trip is a correctness gate, not a performance benchmark"},
      "gate": {"enabled": true, "command": "pnpm --filter @forgeax/hello-m2-content-pipeline smoke"},
      "spike-report": {"enabled": false, "reason": "not a spike app"}
    }
  },
  "dependencies": {
    "@forgeax/engine-codec": "workspace:*",
    "@forgeax/engine-fbx": "workspace:*",
    "@forgeax/engine-image": "workspace:*",
    "@forgeax/engine-pack": "workspace:*",
    "@forgeax/engine-project": "workspace:*"
  }
}
