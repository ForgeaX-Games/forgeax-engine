{
  "name": "@forgeax/hello-fbx-cube",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "feat-20260615-fbx-importer-via-sdk M3 convergence app — cube.fbx via FBX SDK native binding. End-to-end proof of the fbxImporter pipeline: declare+import+loadByGuid<SceneAsset>+instantiate.",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-dawn.mjs",
    "smoke:browser": "node scripts/smoke-browser.mjs"
  },
  "forgeax": {
    "smokeInvocation": "pnpm --filter @forgeax/hello-fbx-cube smoke",
    "metrics": {
      "bundle-size": { "enabled": false, "reason": "vite app bundle downstream of @forgeax/engine-runtime" },
      "fps": { "enabled": false, "reason": "hello-cube anchor only; structural-smoke covers 300-frame GPU path" },
      "bench": { "enabled": false, "reason": "convergence integration app" },
      "gate": { "enabled": true, "command": "pnpm --filter @forgeax/hello-fbx-cube smoke" },
      "spike-report": { "enabled": false, "reason": "not a spike app" }
    }
  },
  "dependencies": {
    "@forgeax/engine-app": "workspace:*",
    "@forgeax/engine-ecs": "workspace:*",
    "@forgeax/engine-fbx": "workspace:*",
    "@forgeax/engine-math": "workspace:*",
    "@forgeax/engine-pack": "workspace:*",
    "@forgeax/engine-runtime": "workspace:*",
    "@forgeax/engine-types": "workspace:*"
  },
  "devDependencies": {
    "@forgeax/engine-shader": "workspace:*",
    "@forgeax/engine-vite-plugin-pack": "workspace:*",
    "@forgeax/engine-vite-plugin-shader": "workspace:*",
    "@types/node": "^25.8.0",
    "@webgpu/types": "^0.1.71",
    "vite": "8.0.10",
    "webgpu": "^0.4.0"
  }
}