{
  "name": "@forgeax/hello-video-cutscene",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "feat-20260617 M4 host-engine contract worked example -- pause -> DOM <video> overlay -> resume cutscene with zero engine video code.",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-dawn.mjs",
    "smoke:browser": "node scripts/smoke-browser.mjs"
  },
  "forgeax": {
    "smokeInvocation": "pnpm --filter @forgeax/hello-video-cutscene smoke",
    "metrics": {
      "bundle-size": {
        "enabled": false,
        "reason": "vite app bundle shape downstream of @forgeax/engine-runtime sizes already tracked at the package level"
      },
      "fps": {
        "enabled": false,
        "reason": "host-engine contract demo; fps tracked by hello-triangle"
      },
      "bench": {
        "enabled": false,
        "reason": "demo app; bench focus stays on @forgeax/engine-math"
      },
      "gate": {
        "enabled": true,
        "command": "pnpm --filter @forgeax/hello-video-cutscene smoke"
      },
      "spike-report": {
        "enabled": false,
        "reason": "not a spike app"
      }
    }
  },
  "dependencies": {
    "@forgeax/engine-app": "workspace:*",
    "@forgeax/engine-runtime": "workspace:*",
    "@forgeax/engine-math": "workspace:*",
    "@forgeax/engine-types": "workspace:*"
  },
  "devDependencies": {
    "@forgeax/engine-vite-plugin-shader": "workspace:*",
    "vite": "8.0.10",
    "webgpu": "^0.4.0",
    "@webgpu/types": "^0.1.70"
  }
}
