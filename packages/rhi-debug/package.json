{
  "name": "@forgeax/engine-rhi-debug",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "description": "RenderDoc-inspired RHI frame record + deterministic replay + offline inspect for forgeax-engine. First user is AI subagent; exposed via WS:5732 JSON-RPC, CLI, and direct import.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "import": "./dist/adapter.mjs"
    },
    "./capture-browser": {
      "types": "./dist/capture-browser.d.ts",
      "import": "./dist/capture-browser.mjs"
    },
    "./inspector": {
      "types": "./dist/inspector.d.ts",
      "import": "./dist/inspector.mjs"
    },
    "./inspect-core": {
      "types": "./dist/inspect-core.d.ts",
      "import": "./dist/inspect-core.mjs"
    },
    "./frame-model": {
      "types": "./dist/frame-model.d.ts",
      "import": "./dist/frame-model.mjs"
    },
    "./rt-to-canvas": {
      "types": "./dist/rt-to-canvas.d.ts",
      "import": "./dist/rt-to-canvas.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "forgeax-rhi-debug": "./dist/cli.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@forgeax/engine-rhi": "workspace:*",
    "@forgeax/engine-types": "workspace:*",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pngjs": "^6.0.5",
    "@webgpu/types": "^0.1.70",
    "webgpu": "^0.4.0"
  },
  "peerDependencies": {
    "@forgeax/engine-rhi-webgpu": "workspace:*",
    "@forgeax/engine-rhi-wgpu": "workspace:*"
  },
  "forgeax": {
    "metrics": {
      "bundle-size": {
        "enabled": true,
        "path": "dist/index.mjs",
        "compression": "gzip"
      },
      "fps": {
        "enabled": false,
        "reason": "debug instrumentation package, no hot render path"
      },
      "bench": {
        "enabled": false,
        "reason": "instrumentation package; bench focus stays on runtime/rhi"
      },
      "gate": {
        "enabled": false,
        "reason": "r12-lint runs at repo root via root package.json#scripts.r12-lint; not modelled as a per-package metric gate yet"
      },
      "spike-report": {
        "enabled": false,
        "reason": "not a spike package"
      }
    }
  }
}