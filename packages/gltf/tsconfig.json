{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": [
      "@webgpu/types",
      "node"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "references": [
    {
      "path": "../assets-runtime"
    },
    {
      "path": "../import"
    },
    {
      "path": "../math"
    },
    {
      "path": "../pack"
    },
    {
      "path": "../types"
    }
  ]
}
