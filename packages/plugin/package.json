{
  "name": "@forgeax/engine-plugin",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "description": "Thin protocol-layer package for Plugin interface + PluginError; sits above @forgeax/engine-ecs and below capability packages.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@forgeax/engine-ecs": "workspace:*"
  },
  "forgeax": {
    "metrics": {
      "bundle-size": {
        "enabled": true,
        "path": "dist/index.mjs",
        "compression": "gzip"
      },
      "fps": {
        "enabled": false,
        "reason": "pure protocol-layer package; no runtime canvas"
      },
      "bench": {
        "enabled": false,
        "reason": "zero runtime logic; correctness verified by unit tests"
      },
      "gate": {
        "enabled": false,
        "reason": "no package-level binary gate; AC surface covered by pnpm test:unit"
      },
      "spike-report": {
        "enabled": false,
        "reason": "not a spike package"
      }
    }
  }
}