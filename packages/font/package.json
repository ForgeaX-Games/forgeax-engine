{
  "name": "@forgeax/engine-font",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "description": "Build-time MSDF font atlas baking and runtime font asset loading for the forgeax engine. CLI surface is provided by @forgeax/engine-console (forgeax-engine-console-font).",
  "bin": {
    "forgeax-engine-console-font": "./dist/cli-font.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./font-importer": {
      "types": "./dist/font-importer.d.ts",
      "node": {
        "import": "./dist/font-importer.mjs"
      },
      "default": null
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@forgeax/engine-types": "workspace:*",
    "@forgeax/engine-pack": "workspace:*",
    "@zappar/msdf-generator": "1.2.4"
  },
  "devDependencies": {
    "@forgeax/engine-console": "workspace:*",
    "@forgeax/engine-import": "workspace:*",
    "@types/node": "^20.14.0"
  },
  "forgeax": {
    "metrics": {
      "bundle-size": {
        "enabled": true,
        "path": "dist/cli-font.mjs",
        "compression": "gzip"
      },
      "fps": {
        "enabled": false,
        "reason": "build-time CLI package; no runtime canvas or frame loop"
      },
      "bench": {
        "enabled": false,
        "reason": "one-shot bake pipeline; not a perf-critical hot path"
      },
      "gate": {
        "enabled": false,
        "reason": "per-package gate tests declared in package.json scripts; no standalone binary gate"
      },
      "spike-report": {
        "enabled": false,
        "reason": "not a spike package"
      }
    }
  }
}
