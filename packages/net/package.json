{
  "name": "@forgeax/engine-net",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "description": "Memory network transport, replication session, and profile-driven ECS sync for forgeax Engine.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@forgeax/engine-ecs": "workspace:*",
    "@forgeax/engine-plugin": "workspace:*",
    "@forgeax/engine-types": "workspace:*"
  },
  "forgeax": {
    "metrics": {
      "bundle-size": {
        "enabled": true,
        "path": "dist/index.mjs",
        "compression": "gzip"
      },
      "fps": {
        "enabled": false,
        "reason": "library package; no runtime canvas; E2E proof deferred to Loop 3"
      },
      "bench": {
        "enabled": false,
        "reason": "no performance benchmarks; deterministic correctness verified by unit and model tests"
      },
      "gate": {
        "enabled": false,
        "reason": "no package-level binary gate; net correctness gated by pnpm test:unit"
      },
      "spike-report": {
        "enabled": false,
        "reason": "not a spike package"
      }
    }
  }
}
