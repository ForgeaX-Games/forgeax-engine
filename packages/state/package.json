{
  "name": "@forgeax/engine-state",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "description": "Single-world typed-state machine with state-scoped entity lifecycle.",
  "bin": {
    "forgeax-engine-console-state": "./dist/cli-state.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@forgeax/engine-ecs": "workspace:*",
    "@forgeax/engine-plugin": "workspace:*",
    "@forgeax/engine-types": "workspace:*"
  },
  "forgeax": {
    "metrics": {
      "bundle-size": {
        "enabled": true,
        "path": "dist/index.mjs",
        "compression": "gzip"
      },
      "fps": {
        "enabled": false,
        "reason": "library package, no runtime canvas; fps reported by hello-level-switch app"
      },
      "bench": {
        "enabled": false,
        "reason": "bench focus stays on engine-math; state correctness verified by unit tests"
      },
      "gate": {
        "enabled": false,
        "reason": "no package-level binary gate; smoke gate covered by hello-level-switch app"
      },
      "spike-report": {
        "enabled": false,
        "reason": "not a spike package"
      }
    }
  }
}