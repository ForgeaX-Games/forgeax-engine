{
  "version": 2,
  "extractionRoot": ".",
  "description": "Build artifact class and consumer contract for cross-job CI transfer. SSOT for file classes, consumer requirements, timing roster (AC-06), and provenance chain.",
  "artifactClasses": {
    "engine-dist": {
      "description": "Package dist outputs (engine runtime, types, ECS, math, all packages)",
      "fileClasses": ["packages/*/dist"],
      "transferArtifact": "core-build"
    },
    "wasm-runtime": {
      "description": "wgpu-wasm runtime package (Rust-to-WASM bridge)",
      "fileClasses": ["packages/wgpu-wasm/pkg"],
      "transferArtifact": "core-build"
    },
    "wasm-fbx": {
      "description": "FBX WASM parser package",
      "fileClasses": ["packages/fbx/pkg"],
      "transferArtifact": "core-build"
    },
    "wasm-codec": {
      "description": "Codec WASM package (KTX2/Basis transcode)",
      "fileClasses": ["packages/codec/pkg"],
      "transferArtifact": "core-build"
    },
    "shared-asset-pack": {
      "description": "App-neutral LearnOpenGL pack payload produced once by shared-app-inputs",
      "fileClasses": ["shared-app-inputs/assets/catalog.json"],
      "transferArtifact": "shared-app-inputs"
    },
    "shared-engine-shaders": {
      "description": "Engine built-in shader payload produced once by shared-app-inputs",
      "fileClasses": ["shared-app-inputs/shaders/manifest.json"],
      "transferArtifact": "shared-app-inputs"
    },
    "app-dist-0": {
      "description": "App shader manifests produced by app-shard-0; payload membership is proven by its artifact inventory.",
      "fileClasses": ["apps/**/dist/shaders/manifest.json"]
    },
    "app-dist-1": {
      "description": "App shader manifests produced by app-shard-1; payload membership is proven by its artifact inventory.",
      "fileClasses": ["apps/**/dist/shaders/manifest.json"]
    },
    "app-dist-2": {
      "description": "App shader manifests produced by app-shard-2; payload membership is proven by its artifact inventory.",
      "fileClasses": ["apps/**/dist/shaders/manifest.json"]
    }
  },
  "consumers": {
    "app-shard": {
      "description": "Core artifact inputs required before every app shard build.",
      "requiredArtifactClasses": [
        "engine-dist",
        "wasm-runtime",
        "wasm-fbx",
        "wasm-codec",
        "shared-asset-pack",
        "shared-engine-shaders"
      ]
    },
    "primary-pnpm": {
      "description": "pnpm CI source of truth: unit tests, typecheck, coverage, inspector e2e",
      "requiredArtifactClasses": [
        "engine-dist",
        "wasm-runtime",
        "app-dist-0",
        "app-dist-1",
        "app-dist-2"
      ]
    },
    "coverage-pnpm": {
      "description": "Vitest coverage and typecheck gate with perf-budget evidence",
      "requiredArtifactClasses": [
        "engine-dist",
        "wasm-runtime",
        "app-dist-0",
        "app-dist-1",
        "app-dist-2"
      ]
    },
    "vitest-browser": {
      "description": "Browser-based vitest tests (chromium WebGPU)",
      "requiredArtifactClasses": [
        "engine-dist",
        "wasm-runtime",
        "app-dist-0",
        "app-dist-1",
        "app-dist-2"
      ]
    },
    "shared-inputs-browser": {
      "description": "Preview asset catalog and Vite shader HMR browser probe",
      "requiredArtifactClasses": [
        "engine-dist",
        "wasm-runtime",
        "app-dist-0",
        "app-dist-1",
        "app-dist-2"
      ]
    },
    "smoke-fleet": {
      "description": "Dawn-node headless smoke tests (~50 demos)",
      "requiredArtifactClasses": [
        "engine-dist",
        "wasm-runtime",
        "app-dist-0",
        "app-dist-1",
        "app-dist-2"
      ]
    },
    "bevy-smoke-fleet": {
      "description": "Bevy Dawn-node build and smoke pairs",
      "requiredArtifactClasses": [
        "engine-dist",
        "wasm-runtime",
        "app-dist-0",
        "app-dist-1",
        "app-dist-2"
      ]
    },
    "vitest-dawn": {
      "description": "Dawn-native vitest tests",
      "requiredArtifactClasses": ["engine-dist", "wasm-runtime"]
    },
    "webkit-fallback": {
      "description": "WebKit verify gate",
      "requiredArtifactClasses": ["engine-dist", "wasm-runtime"]
    },
    "portability-bun": {
      "description": "Bun channel portability gate (6 aligned base gates)",
      "requiredArtifactClasses": [
        "engine-dist",
        "wasm-runtime",
        "app-dist-0",
        "app-dist-1",
        "app-dist-2"
      ]
    },
    "metrics-validate": {
      "description": "Metrics validation (FPS, bench, bundle-size)",
      "requiredArtifactClasses": [
        "engine-dist",
        "wasm-runtime",
        "app-dist-0",
        "app-dist-1",
        "app-dist-2"
      ]
    },
    "collectathon-boot-e2e": {
      "description": "Collectathon game bootstrap e2e test",
      "requiredArtifactClasses": [
        "engine-dist",
        "wasm-runtime",
        "app-dist-0",
        "app-dist-1",
        "app-dist-2"
      ]
    },
    "publish-fbx-wasm-release": {
      "description": "Publish the FBX WASM payload from core-build on a main push",
      "requiredArtifactClasses": ["wasm-fbx"]
    },
    "publish-wgpu-wasm-release": {
      "description": "Publish the wgpu-wasm payload from core-build on a main push",
      "requiredArtifactClasses": ["wasm-runtime"]
    },
    "publish-basis-wasm-release": {
      "description": "Publish the codec WASM payload from core-build on a main push",
      "requiredArtifactClasses": ["wasm-codec"]
    }
  },
  "timingRoster": [
    {
      "jobIdentity": "app-shard-0",
      "artifactProvider": "shared-app-inputs",
      "allowedNonArtifactPrerequisites": ["core-build"],
      "consumer": "app-shard"
    },
    {
      "jobIdentity": "app-shard-1",
      "artifactProvider": "shared-app-inputs",
      "allowedNonArtifactPrerequisites": ["core-build"],
      "consumer": "app-shard"
    },
    {
      "jobIdentity": "app-shard-2",
      "artifactProvider": "shared-app-inputs",
      "allowedNonArtifactPrerequisites": ["core-build"],
      "consumer": "app-shard"
    },
    {
      "jobIdentity": "primary-pnpm",
      "artifactProvider": "build-artifacts",
      "allowedNonArtifactPrerequisites": ["post-merge-gate"],
      "consumer": "primary-pnpm"
    },
    {
      "jobIdentity": "vitest-browser",
      "artifactProvider": "build-artifacts",
      "allowedNonArtifactPrerequisites": ["post-merge-gate"],
      "consumer": "vitest-browser"
    },
    {
      "jobIdentity": "shared-inputs-browser",
      "artifactProvider": "build-artifacts",
      "allowedNonArtifactPrerequisites": ["post-merge-gate"],
      "consumer": "shared-inputs-browser"
    },
    {
      "jobIdentity": "smoke-fleet",
      "artifactProvider": "build-artifacts",
      "allowedNonArtifactPrerequisites": ["post-merge-gate"],
      "consumer": "smoke-fleet"
    },
    {
      "jobIdentity": "bevy-smoke-fleet",
      "artifactProvider": "build-artifacts",
      "allowedNonArtifactPrerequisites": ["post-merge-gate"],
      "consumer": "bevy-smoke-fleet"
    },
    {
      "jobIdentity": "coverage-pnpm",
      "artifactProvider": "build-artifacts",
      "allowedNonArtifactPrerequisites": ["post-merge-gate"],
      "consumer": "coverage-pnpm"
    },
    {
      "jobIdentity": "vitest-dawn",
      "artifactProvider": "core-build",
      "allowedNonArtifactPrerequisites": ["post-merge-gate"],
      "consumer": "vitest-dawn"
    },
    {
      "jobIdentity": "webkit-fallback",
      "artifactProvider": "core-build",
      "allowedNonArtifactPrerequisites": ["post-merge-gate"],
      "consumer": "webkit-fallback"
    },
    {
      "jobIdentity": "portability-bun",
      "artifactProvider": "build-artifacts",
      "allowedNonArtifactPrerequisites": ["post-merge-gate"],
      "consumer": "portability-bun"
    },
    {
      "jobIdentity": "metrics-validate",
      "artifactProvider": "build-artifacts",
      "allowedNonArtifactPrerequisites": ["post-merge-gate"],
      "consumer": "metrics-validate"
    },
    {
      "jobIdentity": "collectathon-boot-e2e",
      "artifactProvider": "build-artifacts",
      "allowedNonArtifactPrerequisites": ["post-merge-gate"],
      "consumer": "collectathon-boot-e2e"
    },
    {
      "jobIdentity": "publish-fbx-wasm-release",
      "allowedNonArtifactPrerequisites": [],
      "notApplicable": true,
      "notApplicableReason": "PR timing window only; this publisher runs on main pushes",
      "consumer": "publish-fbx-wasm-release"
    },
    {
      "jobIdentity": "publish-wgpu-wasm-release",
      "allowedNonArtifactPrerequisites": [],
      "notApplicable": true,
      "notApplicableReason": "PR timing window only; this publisher runs on main pushes",
      "consumer": "publish-wgpu-wasm-release"
    },
    {
      "jobIdentity": "publish-basis-wasm-release",
      "allowedNonArtifactPrerequisites": [],
      "notApplicable": true,
      "notApplicableReason": "PR timing window only; this publisher runs on main pushes",
      "consumer": "publish-basis-wasm-release"
    }
  ],
  "provenance": {
    "producerRoster": [
      "core-build",
      "shared-app-inputs",
      "app-shard-0",
      "app-shard-1",
      "app-shard-2"
    ],
    "namingTemplate": "provenance-<producerJobId>-a<runAttempt>",
    "mergedClass": "provenance-merged",
    "mergedWriter": "build-artifacts",
    "mergedReader": "cost-reporter",
    "payloadClasses": [
      "engine-dist",
      "wasm-runtime",
      "wasm-fbx",
      "wasm-codec",
      "shared-asset-pack",
      "shared-engine-shaders",
      "app-dist-0",
      "app-dist-1",
      "app-dist-2"
    ]
  },
  "sharedInputs": {
    "producer": "shared-app-inputs",
    "consumer": "app-shard",
    "schemaVersion": 1,
    "manifestPath": "shared-app-inputs/manifest.json",
    "inventory": [
      "shared-app-inputs/assets/catalog.json",
      "shared-app-inputs/shaders/manifest.json"
    ],
    "payload": {
      "assetCatalog": "shared-app-inputs/assets/catalog.json",
      "engineShaderManifest": "shared-app-inputs/shaders/manifest.json"
    },
    "payloadClasses": ["shared-asset-pack", "shared-engine-shaders"],
    "artifactOutput": "shared_artifact_id"
  },
  "requiredCIJobRoster": [
    "post-merge-gate",
    "shared-app-inputs",
    "build-artifacts",
    "primary-pnpm",
    "coverage-pnpm",
    "vitest-browser",
    "shared-inputs-browser",
    "smoke-fleet",
    "bevy-smoke-fleet",
    "vitest-dawn",
    "webkit-fallback",
    "portability-bun",
    "metrics-validate",
    "collectathon-boot-e2e",
    "publish-fbx-wasm-release",
    "publish-wgpu-wasm-release",
    "publish-basis-wasm-release",
    "sticky-comment"
  ],
  "shardFamilies": [
    {
      "id": "app-dist",
      "members": ["app-dist-0", "app-dist-1", "app-dist-2"],
      "producerMapping": {
        "app-dist-0": "app-shard-0",
        "app-dist-1": "app-shard-1",
        "app-dist-2": "app-shard-2"
      },
      "inventoryRequired": true
    }
  ]
}
