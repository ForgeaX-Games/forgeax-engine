{
  "name": "forgeax-engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript game engine monorepo (math + core + engine, dual pnpm/bun pipeline).",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@11.7.0",
  "workspaces": [
    "packages/*",
    "apps/*",
    "apps/hello/*",
    "apps/parity/*",
    "apps/learn-render/*/*",
    "apps/learn-render/*/*/*",
    "templates/game-default"
  ],
  "scripts": {
    "build": "pnpm -r build && tsc -b",
    "build:apps": "node scripts/build-apps.mjs",
    "typecheck": "tsc -b && node scripts/typecheck-apps.mjs",
    "test": "vitest run --project='@forgeax/*' --project=hello-triangle --project=unit",
    "test:unit": "vitest run --project='@forgeax/*' --project=hello-triangle --project=unit",
    "test:browser": "vitest run --project=browser",
    "test:browser:watch": "vitest --project=browser",
    "test:browser:wgpu-wasm": "vitest run --project=browser packages/engine/__tests__/renderer-wgpu-wasm.browser.test.ts",
    "test:dawn": "pnpm -r build && vitest run --project=dawn",
    "test:browser-no-webgpu": "vitest run --project=browser-no-webgpu",
    "test:portability": "vitest run --project='@forgeax/engine-math' --project='@forgeax/engine-ecs'",
    "test:all": "pnpm test:unit && pnpm test:browser && pnpm test:dawn",
    "test:watch": "vitest",
    "test:type": "vitest run --project='@forgeax/*' --project=hello-triangle --project=unit --typecheck",
    "r12-lint": "node packages/rhi/scripts/r12-lint.mjs",
    "lint:grep": "node scripts/lint/grep-r12-lint.mjs && node scripts/lint/grep-error-hints.mjs && node scripts/lint/grep-pbr-ibl-callsite.mjs && node scripts/lint/grep-console-errors.mjs && node scripts/lint/grep-pass-kind.mjs && node scripts/grep/check-pack-schema-dist-fresh.mjs && node scripts/grep/check-csm-unique-shadow-path.mjs",
    "grep:r12-lint": "node scripts/lint/grep-r12-lint.mjs",
    "grep:error-hints": "node scripts/lint/grep-error-hints.mjs",
    "grep:pbr-ibl-callsite": "node scripts/lint/grep-pbr-ibl-callsite.mjs",
    "grep:console-errors": "node scripts/lint/grep-console-errors.mjs",
    "grep:pass-kind": "node scripts/lint/grep-pass-kind.mjs",
    "grep:pack-schema-fresh": "node scripts/grep/check-pack-schema-dist-fresh.mjs",
    "lint:internal": "node scripts/lint-internal.mjs",
    "check-engine-no-console-dep": "node packages/console/scripts/check-engine-no-console-dep.mjs",
    "check-console-not-in-engine-bundle": "node packages/console/scripts/check-console-not-in-engine-bundle.mjs",
    "grep:single-exit": "node packages/ecs/scripts/check-single-exit.mjs",
    "grep:asset-registry-instanced-removed": "node scripts/grep/check-asset-registry-instanced-removed.mjs",
    "grep:no-entity-array-literal": "node scripts/grep/check-no-entity-array-literal.mjs",
    "grep:readme-array-vocab-mentioned": "node scripts/grep/check-readme-array-vocab-mentioned.mjs",
    "grep:readme-string-vocab-mentioned": "node scripts/grep/check-readme-string-vocab-mentioned.mjs",
    "grep:no-managed-array-view-import": "node scripts/grep/check-no-managed-array-view-import.mjs",
    "grep:no-array-stride-option": "node scripts/grep/check-no-array-stride-option.mjs",
    "grep:no-buffer-colon-keyword": "node scripts/grep/check-no-buffer-colon-keyword.mjs",
    "grep:no-managed-array-error-code": "node scripts/grep/check-no-managed-array-error-code.mjs",
    "grep:no-result-reproject-cast": "node scripts/grep/check-no-result-reproject-cast.mjs",
    "grep:no-string-view-import": "node packages/ecs/scripts/grep-no-string-view-import.mjs",
    "grep:no-set-managed-ref-store": "node packages/ecs/scripts/grep-no-set-managed-ref-store.mjs",
    "grep:no-binary-assets": "node scripts/grep/check-no-binary-assets.mjs",
    "grep:no-shader-manifest-url-literal": "node scripts/grep/check-no-shader-manifest-url-literal.mjs",
    "grep:cluster-forward-variant-gate": "node scripts/grep/check-cluster-forward-variant-gate.mjs",
    "grep:csm-unique-shadow-path": "node scripts/grep/check-csm-unique-shadow-path.mjs",
    "lint": "node scripts/lint-biome-strict.mjs",
    "format": "biome check --write .",
    "bench:pixel-parity": "node scripts/bench/pixel-parity.mjs",
    "bench:nineslice": "node scripts/bench/bench-nineslice-100panel.mjs",
    "ci:channel-align": "node scripts/check-ci-channel-alignment.mjs",
    "ci:paths-sync": "node scripts/ci/sync-paths.mjs",
    "ci:paths-check": "node scripts/ci/sync-paths.mjs --check",
    "dependabot:dryrun": "node scripts/dependabot/dryrun.mjs",
    "dependabot:check-doc-anchor": "node scripts/dependabot/check-doc-anchor.mjs",
    "dup-check": "node scripts/dup-check.mjs",
    "metrics:check": "node scripts/check-metrics-declared.mjs",
    "metrics:report": "node scripts/metrics/render-sticky.mjs",
    "metrics:run": "node scripts/metrics/run-all.mjs",
    "metrics:run-fps": "node scripts/metrics/run-fps.mjs",
    "sync": "node scripts/sync.mjs",
    "sync:check": "node scripts/check-workspaces-equivalence.mjs",
    "harness:sync": "node scripts/sync-harness.mjs",
    "fbx:setup": "node scripts/setup-fbx-sdk.mjs",
    "postinstall": "node scripts/sync-harness.mjs",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@changesets/cli": "2.31.0",
    "@fast-check/vitest": "0.4.1",
    "@forgeax/engine-ecs": "workspace:*",
    "@forgeax/engine-image": "workspace:*",
    "@forgeax/engine-pack": "workspace:*",
    "@forgeax/engine-runtime": "workspace:*",
    "@forgeax/engine-vite-plugin-pack": "workspace:*",
    "@forgeax/engine-vite-plugin-shader": "workspace:*",
    "@types/jscodeshift": "^17.3.0",
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "ajv": "^8.17.1",
    "fast-check": "4.7.0",
    "jscodeshift": "^17.3.0",
    "jscpd": "^4.1.1",
    "pixelmatch": "^7.0.0",
    "playwright": "^1.56.1",
    "simple-git-hooks": "2.13.1",
    "ts-morph": "^28.0.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "upng-js": "^2.1.0",
    "vitest": "4.1.5",
    "wait-on": "^7.2.0",
    "webgpu": "^0.4.0"
  },
  "simple-git-hooks": {
    "pre-commit": "node scripts/check-workspaces-equivalence.mjs && node scripts/check-staged-lockfiles.mjs"
  },
  "forgeax": {
    "metrics": {
      "gate": {
        "enabled": true,
        "command": "pnpm dup-check",
        "cwd": "."
      }
    }
  }
}
